# ─────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────

# Option 1: OpenAI (used when deployed to Render or any cloud)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Option 2: Local Ollama (used when OPENAI_API_KEY is blank)
# Requires Ollama running on your machine: https://ollama.com
OLLAMA_HOST=http://localhost:11434
